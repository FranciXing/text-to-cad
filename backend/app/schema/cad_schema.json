{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "text-to-cad-schema-v1",
  "title": "Text-to-CAD Modeling Plan",
  "type": "object",
  "required": ["version", "metadata", "steps"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "metadata": {
      "type": "object",
      "required": ["design_name"],
      "properties": {
        "design_name": { "type": "string" },
        "description": { "type": "string" },
        "units": {
          "type": "string",
          "enum": ["mm", "cm", "m", "inch"],
          "default": "mm"
        }
      }
    },
    "parameters": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "value": { "type": "number" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "id"],
            "properties": {
              "type": { "const": "sketch" },
              "id": { "type": "string" },
              "plane": {
                "oneOf": [
                  { "enum": ["XY", "YZ", "XZ"] },
                  {
                    "type": "object",
                    "properties": {
                      "origin": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                      "normal": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
                    }
                  }
                ]
              },
              "entities": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["type"],
                      "properties": {
                        "type": { "const": "rectangle" },
                        "width": { "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }] },
                        "height": { "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }] },
                        "centered": { "type": "boolean", "default": true }
                      }
                    },
                    {
                      "type": "object",
                      "required": ["type", "center", "radius"],
                      "properties": {
                        "type": { "const": "circle" },
                        "center": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
                        "radius": { "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }] }
                      }
                    }
                  ]
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "sketch_id", "distance"],
            "properties": {
              "type": { "const": "extrude" },
              "sketch_id": { "type": "string" },
              "distance": { "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^\\$[a-zA-Z_][a-zA-Z0-9_]*$" }] },
              "operation": { "type": "string", "enum": ["new", "add", "cut"], "default": "new" }
            }
          },
          {
            "type": "object",
            "required": ["type", "position", "diameter"],
            "properties": {
              "type": { "const": "hole" },
              "position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
              "diameter": { "oneOf": [{ "type": "number" }, { "type": "string" }] },
              "depth": { "type": "number" },
              "through_all": { "type": "boolean", "default": false }
            }
          },
          {
            "type": "object",
            "required": ["type", "radius"],
            "properties": {
              "type": { "const": "fillet" },
              "edges": { "type": "string", "enum": ["all"] },
              "radius": { "type": "number" }
            }
          }
        ]
      }
    }
  }
}
