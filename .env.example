# Text-to-CAD 环境变量配置

# ============================================
# 后端配置
# ============================================

# 应用配置
APP_NAME=Text-to-CAD
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production

# 服务器配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# ============================================
# 数据库配置
# ============================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=texttocad
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=texttocad
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis (用于缓存和 Celery)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Celery 配置
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ============================================
# 文件存储配置 (MinIO/S3)
# ============================================

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=texttocad-models
MINIO_SECURE=false

# AWS S3 (如果使用 S3 而不是 MinIO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=

# ============================================
# LLM API 配置
# ============================================

# OpenAI (用于 GPT-4)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4

# Anthropic (用于 Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 默认使用的 LLM
DEFAULT_LLM_PROVIDER=anthropic  # 或 openai

# ============================================
# CAD 配置
# ============================================

# CadQuery 配置
CQ_TOLERANCE=0.01
CQ_ANGULAR_TOLERANCE=0.1

# 预览生成配置
PREVIEW_MESH_QUALITY=0.1  # 网格质量，越小越精细但文件越大
PREVIEW_FORMAT=gltf       # gltf 或 stl

# ============================================
# 任务队列配置
# ============================================

# 任务超时设置（秒）
TASK_TIMEOUT_LLM=300
TASK_TIMEOUT_CAD=600
TASK_TIMEOUT_PREVIEW=120

# 最大重试次数
MAX_RETRIES=3

# 并发设置
MAX_CONCURRENT_LLM_TASKS=5
MAX_CONCURRENT_CAD_TASKS=3

# ============================================
# 日志配置
# ============================================

LOG_LEVEL=INFO
LOG_FORMAT=json  # json 或 text

# ============================================
# 安全配置
# ============================================

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 速率限制
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================
# 开发配置
# ============================================

# 热重载
RELOAD=true

# 调试工具
ENABLE_DEBUG_TOOLBAR=false
